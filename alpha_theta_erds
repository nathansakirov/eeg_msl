merged_df = pd.merge(dfpower_allbands_fam28, baseline_power_fam28, on='freq')
merged_df['ERDS_RPF'] = ((merged_df['RPF'] - merged_df['baseline_power_RPF']) / merged_df['baseline_power_RPF']) * 100
merged_df['ERDS_LPF'] = ((merged_df['LPF'] - merged_df['baseline_power_LPF']) / merged_df['baseline_power_LPF']) * 100
merged_df['ERDS_CC'] = ((merged_df['CC'] - merged_df['baseline_power_CC']) / merged_df['baseline_power_CC']) * 100

